# URL base del backend Nest (sin barra final). Debe coincidir con el puerto del API (3001).
# Usada en next.config (rewrites /api → backend) y disponible en el cliente si necesitás URLs absolutas.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Opcional: solo build/servidor Next; si no existe, se usa NEXT_PUBLIC_API_URL
# BACKEND_URL=http://localhost:3001
