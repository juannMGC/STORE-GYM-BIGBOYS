# --- API Nest (proxy /api → backend) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
# Opcional: solo servidor (rewrites). Si falta, se usa NEXT_PUBLIC_API_URL.
# BACKEND_URL=http://localhost:3001

# Misma API Identifier que en Auth0 Dashboard y que AUTH0_AUDIENCE del backend Nest.
# Obligatoria en el cliente para getAccessToken → llamadas al API con Bearer.
NEXT_PUBLIC_AUTH0_AUDIENCE=https://tu-api.example.com

# --- Auth0 (@auth0/nextjs-auth0 v4) ---
# Copiá este archivo a .env.local (minúsculas, en la carpeta frontend). No uses AUTH0_ISSUER_BASE_URL ni AUTH0_BASE_URL (eran de v3).
# Dominio del tenant (sin https), ej: dev-xxxxx.us.auth0.com — debe ser el MISMO que en backend/.env (Auth0 Dashboard → Settings → Domain).
# Si el dominio es viejo o incorrecto, /.well-known/openid-configuration devuelve 404 y el login falla con OAUTH_RESPONSE_IS_NOT_CONFORM.
AUTH0_DOMAIN=
# Aplicación "Regular Web Application" en Auth0
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Secreto para cifrado de cookies de sesión (openssl rand -hex 32)
AUTH0_SECRET=
# URL pública de esta app Next (local: http://localhost:3000)
APP_BASE_URL=http://localhost:3000
# Misma audience que el backend (también en servidor para /authorize)
AUTH0_AUDIENCE=https://tu-api.example.com

# --- Auth0 Dashboard (checklist manual) ---
# 1) APIs: crear API con Identifier = AUTH0_AUDIENCE (= NEXT_PUBLIC_AUTH0_AUDIENCE).
# 2) Application: Regular Web Application; Allowed Callback URLs: {APP_BASE_URL}/auth/callback
# 3) Allowed Logout URLs: {APP_BASE_URL}
# 4) Allowed Web Origins: {APP_BASE_URL}
# 5) Action o Rule: incluir en access token "email" y claim https://myapp.com/roles (ADMIN|CLIENT)
#
# Si ves "An error occurred during the authorization flow": tras volver a intentar login, la página /login
# puede mostrar el motivo real (redirect_uri_mismatch, access_denied, etc.).
# - Callback URL exacta: {APP_BASE_URL}/auth/callback (v4, no /api/auth/callback).
# - Client ID/Secret deben ser de una app en el MISMO tenant que AUTH0_DOMAIN.
# - Si usás audience: en Auth0 → Applications → tu app → APIs → autorizá el API Identifier (AUTH0_AUDIENCE).
#
# Error [access_denied] "Service not found: https://..."  →  Ese URL es AUTH0_AUDIENCE pero no existe
# como API en el tenant. Crear: barra lateral → APIs (sección propia) → Create API → Identifier = AUTH0_AUDIENCE.
# Autorizar: Applications → tu Regular Web App → pestaña APIs → habilitar ese API.
# App y API en el mismo tenant (mismo AUTH0_DOMAIN).
