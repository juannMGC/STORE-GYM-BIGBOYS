generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Valores: CLIENT | ADMIN (ver src/common/constants/roles.ts)
model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  type        String // PERCENT | FIXED
  value       Float
  minPurchase Float     @default(0)
  maxUses     Int?
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  orders      Order[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  /// Solo usuarios con login local (seed); usuarios Auth0 sin contraseña local.
  passwordHash String?
  /// Subject del JWT de Auth0 (`sub`).
  auth0Id      String?  @unique
  name         String?
  phone        String?
  department   String?
  city         String?
  neighborhood String?
  address      String?
  complement   String?
  avatarUrl    String?
  role         String   @default("CLIENT")
  createdAt    DateTime @default(now())
  orders       Order[]
  reviews      Review[]
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String?    @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime   @default(now())
}

model Size {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  products    ProductSize[]
  orderItems  OrderItem[]
}

model Product {
  id          String         @id @default(uuid())
  title       String
  // slug único para URLs /tienda/productos/:slug
  slug        String?        @unique
  description String?
  price       Float
  stock       Int            @default(0)
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images      ProductImage[]
  sizes       ProductSize[]
  orderItems  OrderItem[]
  reviews     Review[]
  createdAt   DateTime       @default(now())
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  title     String?
  body      String
  status    String   @default("PENDING")
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId, status])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductSize {
  productId String
  sizeId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      Size    @relation(fields: [sizeId], references: [id], onDelete: Cascade)

  @@id([productId, sizeId])
}

// status: DRAFT | PAID | SHIPPED | DELIVERED | CANCELLED
// paymentMethod: CASH | BANK_TRANSFER | CARD (opcional hasta checkout)
model Order {
  id                   String      @id @default(uuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               String      @default("DRAFT")
  paymentMethod        String?
  shippingEmail        String?
  shippingDepartment   String?
  shippingCity         String?
  shippingNeighborhood String?
  shippingAddress      String?
  shippingComplement   String?
  couponId             String?
  discountAmount       Float       @default(0)
  coupon               Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model OrderItem {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  sizeId        String?
  size          Size?    @relation(fields: [sizeId], references: [id], onDelete: SetNull)
  quantity      Int
  priceSnapshot Float
}

/// Snapshot de pedido eliminado por admin (solo DELIVERED / CANCELLED).
model OrderHistory {
  id        String   @id @default(uuid())
  orderId   String
  orderData Json
  deletedAt DateTime @default(now())
  deletedBy String
  reason    String?

  @@index([orderId])
  @@index([deletedAt])
}
