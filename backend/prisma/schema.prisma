generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Valores: CLIENT | ADMIN (ver src/common/constants/roles.ts)
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  /// Solo usuarios con login local (seed); usuarios Auth0 sin contraseña local.
  passwordHash String?
  /// Subject del JWT de Auth0 (`sub`), para enlazar y sincronizar.
  auth0Sub     String?  @unique
  role         String   @default("CLIENT")
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String?    @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime   @default(now())
}

model Size {
  id         String        @id @default(uuid())
  name       String
  code       String        @unique
  products   ProductSize[]
  orderItems OrderItem[]
}

model Product {
  id          String         @id @default(uuid())
  title       String
  // slug único para URLs /tienda/productos/:slug
  slug        String?        @unique
  description String?
  price       Float
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images      ProductImage[]
  sizes       ProductSize[]
  orderItems  OrderItem[]
  createdAt   DateTime       @default(now())
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)
}

model ProductSize {
  productId String
  sizeId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      Size    @relation(fields: [sizeId], references: [id], onDelete: Cascade)

  @@id([productId, sizeId])
}

// status: DRAFT | PENDING | PAID | SHIPPED | CANCELLED
// paymentMethod: CASH | BANK_TRANSFER | CARD (opcional hasta checkout)
model Order {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        String      @default("DRAFT")
  paymentMethod String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  sizeId        String?
  size          Size?    @relation(fields: [sizeId], references: [id], onDelete: SetNull)
  quantity      Int
  priceSnapshot Float
}
