# =============================================================================
# Render.com (Web Service del backend) — Environment
# Copiá estas claves al dashboard: Service → Environment → Add Environment Variable
# Sin AUTH0_DOMAIN / AUTH0_AUDIENCE el deploy falla al arrancar Nest.
#
# DATABASE_URL     = Internal Database URL del Postgres en Render (recomendado) o External
# AUTH0_DOMAIN     = mismo valor que en local (ej. dev-xxxxx.us.auth0.com)
# AUTH0_AUDIENCE   = mismo API Identifier que en Auth0 y en el frontend
# CORS_ORIGIN      = URL del frontend en producción (ej. https://tu-app.vercel.app)
# FRONTEND_URL     = misma URL base del Next (redirect post-pago Wompi → /pedido/confirmado)
# PORT             = Render lo inyecta solo; no hace falta definirla
# =============================================================================

# --- Base de datos (PostgreSQL) ---
# Render Postgres: en el dashboard copiá "External Database URL" para desarrollo local / fuera de Render.
# Añadí ?sslmode=require si no viene en la URL (obligatorio para conexiones TLS a Render).
# Ejemplo: postgresql://USER:PASS@dpg-xxxxx.REGION-postgres.render.com:5432/NOMBRE_BD?sslmode=require
# Servicios dentro de Render (misma cuenta/región) pueden usar la "Internal Database URL".
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth0 (API valida JWT con JWKS; el front inicia sesión con Auth0)
# Dominio del tenant (sin https), p. ej. dev-xxxxx.us.auth0.com
AUTH0_DOMAIN="TU_TENANT.us.auth0.com"
# API Identifier configurado en Auth0 (audience del access token)
AUTH0_AUDIENCE="https://tu-api.example.com"

# Auth0 API → Settings: Enable RBAC = ON y "Add Permissions in the Access Token" = ON
# para que el JWT incluya el claim "permissions" (RBAC). El rol en DB se deriva de ahí
# (manage:users → ADMIN; si no, CLIENT) y del respaldo ADMIN_EMAIL abajo.
#
# Opcional (legacy): claim de roles custom; el flujo principal usa "permissions".
# AUTH0_ROLES_CLAIM="https://myapp.com/roles"
# Opcional: si el email no viene en el claim estándar "email"
# AUTH0_EMAIL_CLAIM="https://myapp.com/email"
#
# Si el access token de tu API no trae "email", el primer login puede fallar hasta crear el usuario.
# Auth0 → Actions → Library → Custom → Trigger "Login / Post Login":
#   exports.onExecutePostLogin = async (event, api) => {
#     api.accessToken.setCustomClaim('email', event.user.email);
#   };
# Deploy → Flows → Login → arrastrá la Action. El API (Identifier = AUTH0_AUDIENCE) debe estar autorizado en la app.

# Puerto HTTP del API Nest. Usar 3001 para no chocar con Next.js (3000).
# En Render u otros hosts, suele inyectarse PORT automáticamente.
PORT=3001

# --- Recomendados ---
# Un origen o varios separados por coma (producción / Vercel preview):
# CORS_ORIGIN="https://tu-app.vercel.app,https://www.tudominio.com"
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Seed del usuario administrador (prisma db seed) y pruebas e2e (test/admin-flow.e2e-spec.ts)
# No commitees contraseñas reales; solo valores locales.
# En producción: ejecutá el seed una sola vez tras el primer deploy con ADMIN_PASSWORD fuerte,
# o creá el admin manualmente y no reutilices la contraseña de desarrollo.
# Tras login con Auth0, el mismo email se enlaza con auth0Id automáticamente.
ADMIN_EMAIL="bigboysdevs@gmail.com"
ADMIN_PASSWORD="ChangeMe123!"

# Wompi (Colombia) — sandbox: https://docs.wompi.co/docs/colombia/ambientes-y-llaves/
# Webhook URL en el dashboard: https://TU-API/api/webhooks/wompi
WOMPI_PUBLIC_KEY="pub_test_..."
WOMPI_PRIVATE_KEY="prv_test_..."
WOMPI_INTEGRITY_KEY="test_integrity_..."
WOMPI_EVENTS_KEY="test_events_..."

# Correo (Nodemailer + Gmail SMTP) — https://support.google.com/accounts/answer/185833 (contraseña de aplicación)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="465"
MAIL_USER="bigboysdevs@gmail.com"
MAIL_PASS="xxxxxxxxxxxxxxxx"
MAIL_FROM="Big Boys Gym <bigboysdevs@gmail.com>"
# Alertas de nuevo pedido (opcional; si falta se usa MAIL_USER)
MAIL_ADMIN_TO="admin@bigboys.local"
