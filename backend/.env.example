# --- Base de datos (PostgreSQL) ---
# Render Postgres: en el dashboard copiá "External Database URL" para desarrollo local / fuera de Render.
# Añadí ?sslmode=require si no viene en la URL (obligatorio para conexiones TLS a Render).
# Ejemplo: postgresql://USER:PASS@dpg-xxxxx.REGION-postgres.render.com:5432/NOMBRE_BD?sslmode=require
# Servicios dentro de Render (misma cuenta/región) pueden usar la "Internal Database URL".
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth0 (API valida JWT con JWKS; el front inicia sesión con Auth0)
# Dominio del tenant (sin https), p. ej. dev-xxxxx.us.auth0.com
AUTH0_DOMAIN="TU_TENANT.us.auth0.com"
# API Identifier configurado en Auth0 (audience del access token)
AUTH0_AUDIENCE="https://tu-api.example.com"

# Opcional: claim de roles personalizado (por defecto https://myapp.com/roles)
# AUTH0_ROLES_CLAIM="https://myapp.com/roles"
# Opcional: si el email no viene en el claim estándar "email"
# AUTH0_EMAIL_CLAIM="https://myapp.com/email"

# Puerto HTTP del API Nest. Usar 3001 para no chocar con Next.js (3000).
# En Render u otros hosts, suele inyectarse PORT automáticamente.
PORT=3001

# --- Recomendados ---
# Un origen o varios separados por coma (producción / Vercel preview):
# CORS_ORIGIN="https://tu-app.vercel.app,https://www.tudominio.com"
CORS_ORIGIN="http://localhost:3000"

# Seed del usuario administrador (prisma db seed) y pruebas e2e (test/admin-flow.e2e-spec.ts)
# No commitees contraseñas reales; solo valores locales.
# En producción: ejecutá el seed una sola vez tras el primer deploy con ADMIN_PASSWORD fuerte,
# o creá el admin manualmente y no reutilices la contraseña de desarrollo.
# Tras login con Auth0, el mismo email se enlaza con auth0Sub automáticamente.
ADMIN_EMAIL="admin@bigboys.local"
ADMIN_PASSWORD="ChangeMe123!"
